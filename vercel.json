{
  "functions": {
    "api/classify.js": {
      "maxDuration": 10
    },
    "api/hook.js": {
      "maxDuration": 10
    },
    "api/chat.js": {
      "maxDuration": 25
    },
    "api/re-engagement.js": {
      "maxDuration": 10
    },
    "api/report.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/daily-summary", "schedule": "0 20 * * *" }
  ]
}
